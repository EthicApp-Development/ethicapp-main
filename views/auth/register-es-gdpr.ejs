<!DOCTYPE html>
<html lang="es" ng-app="EthicAppAuth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registro - EthicApp</title>

    <link rel="stylesheet" href="/css/bootstrap5.min.css" />
    <link rel="stylesheet" href="/css/auth.css" />
    <link rel="icon" href="img/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="img/favicon/logo192.png" />
</head>

<body>
    <div class="container auth-page d-flex justify-content-center" ng-controller="RegistrationController">
        <div class="card auth-card">
            <div class="card-body p-4 p-md-5">

                <!-- Header -->
                <div class="text-center mb-4">
                    <img src="img/logos/ethicapp-logo.svg" alt="Logo">
                    <h1 class="h3 auth-title mb-1">Crear cuenta</h1>
                    <p class="text-muted mb-0">Completa tus datos para registrarte</p>
                </div>

                <!-- Error servidor -->
                <div class="alert alert-danger" ng-if="serverError">
                    {{ serverError }}
                </div>

                <!-- Éxito -->
                <div class="alert alert-success" ng-if="registrationSuccess">
                    Cuenta creada correctamente. Ya puedes iniciar sesión.
                </div>

                <!-- Form -->
                <form name="registerForm" novalidate ng-submit="submitRegistration(registerForm)">

                    <!-- Nombre -->
                    <div class="mb-3">
                        <label class="form-label">Nombre</label>
                        <input type="text" name="name" class="form-control" ng-model="formData.name" required />
                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.name.$touched) && registerForm.name.$error.required">
                            El nombre es obligatorio.
                        </div>
                    </div>

                    <!-- Apellido -->
                    <div class="mb-3">
                        <label class="form-label">Apellido</label>
                        <input type="text" name="lastname" class="form-control" ng-model="formData.lastname" required />
                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.lastname.$touched) && registerForm.lastname.$error.required">
                            El apellido es obligatorio.
                        </div>
                    </div>

                    <!-- DNI / RUT -->
                    <div class="mb-3">
                        <label class="form-label">DNI / RUT</label>
                        <input type="text" name="dni" class="form-control" placeholder="Sin puntos, con guión"
                            ng-model="formData.dni" />
                    </div>

                    <!-- Email -->
                    <div class="mb-3">
                        <label class="form-label">Correo electrónico</label>
                        <input type="email" name="email" class="form-control" ng-model="formData.email" required />
                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.email.$touched)">

                            <span ng-if="registerForm.email.$error.required">
                                El correo es obligatorio.
                            </span>

                            <span ng-if="registerForm.email.$error.email">
                                Introduce un correo válido.
                            </span>
                        </div>
                    </div>

                    <!-- Género -->
                    <div class="mb-3">
                        <label class="form-label">Género</label>
                        <select name="gender" class="form-select" ng-model="formData.gender" required>
                            <option value="" disabled selected>Selecciona una opción</option>
                            <option value="F">Femenino</option>
                            <option value="M">Masculino</option>
                            <option value="O">Otro</option>
                        </select>

                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.gender.$touched) && registerForm.gender.$error.required">
                            Debes seleccionar un género.
                        </div>
                    </div>

                    <!-- Contraseña -->
                    <div class="mb-3">
                        <label class="form-label">Contraseña</label>
                        <div class="input-group">
                            <input type="{{ showPassword ? 'text' : 'password' }}" name="password" class="form-control"
                                ng-model="formData.password" password-strength required />

                            <button type="button" class="btn btn-outline-secondary"
                                ng-click="showPassword = !showPassword" tabindex="-1">
                                <span ng-if="!showPassword">Ver</span>
                                <span ng-if="showPassword">Ocultar</span>
                            </button>
                        </div>
                        <div class="form-text">
                            La contraseña debe tener al menos 10 caracteres e incluir al menos 2 símbolos.
                        </div>
                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.password.$touched)">

                            <span ng-if="registerForm.password.$error.required">
                                La contraseña es obligatoria.
                            </span>

                            <span ng-if="registerForm.password.$error.passwordStrength">
                                Debe tener al menos 10 caracteres e incluir al menos 2 símbolos.
                            </span>
                        </div>
                    </div>

                    <!-- Confirmación -->
                    <div class="mb-3">
                        <label class="form-label">Confirmar contraseña</label>

                        <div class="input-group">
                            <input type="{{ showPasswordConfirmation ? 'text' : 'password' }}"
                                name="password_confirmation" class="form-control"
                                ng-model="formData.password_confirmation" required />

                            <button type="button" class="btn btn-outline-secondary"
                                ng-click="showPasswordConfirmation = !showPasswordConfirmation"
                                aria-label="{{ showPasswordConfirmation ? 'Ocultar confirmación de contraseña' : 'Mostrar confirmación de contraseña' }}">
                                <span ng-if="!showPasswordConfirmation">Ver</span>
                                <span ng-if="showPasswordConfirmation">Ocultar</span>
                            </button>
                        </div>

                        <div class="text-danger small mt-1"
                            ng-if="(registerForm.$submitted || registerForm.password_confirmation.$touched)">
                            <span ng-if="registerForm.password_confirmation.$error.required">
                                Debes confirmar la contraseña.
                            </span>

                            <span
                                ng-if="!registerForm.password_confirmation.$error.required && formData.password !== formData.password_confirmation">
                                Las contraseñas no coinciden.
                            </span>
                        </div>
                    </div>

                    <!-- Botón -->
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg" ng-disabled="isSubmitting">
                            <span ng-if="!isSubmitting">Crear cuenta</span>
                            <span ng-if="isSubmitting">Registrando...</span>
                        </button>
                    </div>

                </form>

                <hr class="my-4" />

                <!-- Footer -->
                <p class="text-center mb-0">
                    <span class="text-muted">¿Ya tienes cuenta?</span>
                    <a href="/login" class="text-decoration-none">Iniciar sesión</a>
                </p>

            </div>
        </div>
    </div>

    <script src="/js/angular.min.js"></script>
    <script src="/js/auth.bundle.js"></script>
</body>

</html>