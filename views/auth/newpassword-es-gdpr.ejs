<!DOCTYPE html>
<html lang="es" ng-app="EthicAppAuth">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Restablecer contraseña - EthicApp</title>

    <link rel="stylesheet" href="/css/bootstrap5.min.css" />
    <link rel="stylesheet" href="/css/auth.css" />
    <link rel="icon" href="img/favicon/favicon.ico" />
    <link rel="apple-touch-icon" href="img/favicon/logo192.png" />
</head>

<body>
    <div class="container auth-page d-flex justify-content-center" ng-controller="PasswordRecoveryController">
        <div class="card auth-card">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <img src="img/logos/ethicapp-logo.svg" alt="Logo">
                    <h1 class="h3 auth-title mb-1">Restablecer contraseña</h1>
                    <p class="text-muted mb-0">
                        Introduce tu nueva contraseña para recuperar el acceso
                    </p>
                </div>

                <div class="alert alert-danger" ng-if="serverError">
                    {{ serverError }}
                </div>

                <div class="alert alert-success" ng-if="passwordResetSuccess">
                    Tu contraseña ha sido actualizada correctamente. Ya puedes iniciar sesión.
                </div>

                <div class="alert alert-danger" ng-if="!formData.token">
                    El enlace de recuperación no es válido o no contiene un token.
                </div>

                <form name="newPasswordForm" novalidate ng-submit="submitNewPassword(newPasswordForm)"
                    ng-if="!passwordResetSuccess">
                    <div class="mb-3">
                        <label class="form-label">Nueva contraseña</label>

                        <div class="input-group">
                            <input type="{{ showPassword ? 'text' : 'password' }}" name="password" class="form-control"
                                ng-model="formData.password" password-strength required ng-disabled="!formData.token" />

                            <button type="button" class="btn btn-outline-secondary"
                                ng-click="showPassword = !showPassword"
                                aria-label="{{ showPassword ? 'Ocultar contraseña' : 'Mostrar contraseña' }}"
                                ng-disabled="!formData.token">
                                <span ng-if="!showPassword">Ver</span>
                                <span ng-if="showPassword">Ocultar</span>
                            </button>
                        </div>

                        <div class="text-danger small mt-1"
                            ng-if="(newPasswordForm.$submitted || newPasswordForm.password.$touched)">
                            <span ng-if="newPasswordForm.password.$error.required">
                                La nueva contraseña es obligatoria.
                            </span>

                            <span ng-if="newPasswordForm.password.$error.passwordStrength">
                                Debe tener al menos 10 caracteres e incluir al menos 2 símbolos.
                            </span>
                        </div>

                        <div class="form-text">
                            Mínimo 10 caracteres y al menos 2 símbolos.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Confirmar nueva contraseña</label>

                        <div class="input-group">
                            <input type="{{ showPasswordConfirmation ? 'text' : 'password' }}"
                                name="password_confirmation" class="form-control"
                                ng-model="formData.password_confirmation" required ng-disabled="!formData.token" />

                            <button type="button" class="btn btn-outline-secondary"
                                ng-click="showPasswordConfirmation = !showPasswordConfirmation"
                                aria-label="{{ showPasswordConfirmation ? 'Ocultar confirmación de contraseña' : 'Mostrar confirmación de contraseña' }}"
                                ng-disabled="!formData.token">
                                <span ng-if="!showPasswordConfirmation">Ver</span>
                                <span ng-if="showPasswordConfirmation">Ocultar</span>
                            </button>
                        </div>

                        <div class="text-danger small mt-1"
                            ng-if="(newPasswordForm.$submitted || newPasswordForm.password_confirmation.$touched)">
                            <span ng-if="newPasswordForm.password_confirmation.$error.required">
                                Debes confirmar la nueva contraseña.
                            </span>

                            <span
                                ng-if="!newPasswordForm.password_confirmation.$error.required && formData.password !== formData.password_confirmation">
                                Las contraseñas no coinciden.
                            </span>
                        </div>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg"
                            ng-disabled="isSubmitting || !formData.token">
                            <span ng-if="!isSubmitting">Guardar nueva contraseña</span>
                            <span ng-if="isSubmitting">Actualizando...</span>
                        </button>
                    </div>
                </form>

                <hr class="my-4" />

                <p class="text-center mb-0">
                    <a href="/login" class="text-decoration-none">Volver a iniciar sesión</a>
                </p>
            </div>
        </div>
    </div>

    <script src="/js/angular.min.js"></script>
    <script src="/js/auth.bundle.js"></script>
</body>

</html>