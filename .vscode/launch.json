{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "attach",
            "name": "Attach to Docker",
            "address": "127.0.0.1",
            "port": 9229,
            "restart": true,
            "localRoot": "${workspaceFolder}/ethicapp",
            "remoteRoot": "/home/app",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch EthicApp Frontend",
            "url": "http://localhost:3001",
            "webRoot": "${workspaceFolder}/ethicapp/frontend/assets/js",
            "sourceMaps": true,
            "outFiles": [
                "${workspaceFolder}/ethicapp/frontend/assets/js/dist/*.js"
            ],
            "skipFiles": ["<node_internals>/**"]
        }
    ]
}