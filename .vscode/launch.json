{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "attach",
            "name": "Attach to Docker",
            "address": "localhost",
            "port": 9229,
            "localRoot": "${workspaceFolder}/ethicapp",
            "remoteRoot": "/home/app",
            "skipFiles": ["<node_internals>/**"]
        },
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Launch AngularJS App",
            "url": "http://localhost:3001", // Cambia al puerto donde corre tu servidor local
            "webRoot": "${workspaceFolder}",
            "sourceMaps": true
        }        
    ]
}