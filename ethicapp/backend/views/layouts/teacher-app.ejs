<!DOCTYPE html>
<html ng-app="TeacherApp">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof title !== 'undefined' ? title : "EthicApp" %></title>
  <script src="<%= asset('/js/dist/common-ethicapp-deps.js', '/js/dist/common-ethicapp-deps.min.js') %>" defer></script>
  <link rel="stylesheet" href="<%= asset('/css/dist/assets-bundle.css') %>">
  <link rel="stylesheet" href="/static/fonts/nunito/nunito.css">
  <style>
    [ng-cloak],
    .ng-cloak {
      display: none !important;
    }

    body.teacher-app {
      --global-font-family: "Nunito", "Helvetica Neue", "Helvetica", "Verdana", sans-serif;
      font-family: var(--global-font-family);
    }

    body.teacher-app button,
    body.teacher-app input,
    body.teacher-app optgroup,
    body.teacher-app select,
    body.teacher-app textarea,
    body.teacher-app .popover,
    body.teacher-app .tooltip,
    body.teacher-app .nvtooltip {
      font-family: var(--global-font-family);
    }

    .teacher-bootstrap-screen {
      align-items: center;
      background: #f7f8fa;
      bottom: 0;
      color: #333;
      display: flex;
      flex-direction: column;
      justify-content: center;
      left: 0;
      position: fixed;
      right: 0;
      top: 0;
      z-index: 10000;
    }

    .teacher-bootstrap-logo {
      display: block;
      height: auto;
      margin-bottom: 24px;
      width: 240px;
    }

    .teacher-bootstrap-loader {
      animation: teacherBootstrapPulse 900ms ease-in-out infinite alternate;
      background: #3150f4;
      border-radius: 999px;
      height: 5px;
      width: 140px;
    }

    .teacher-bootstrap-message {
      color: #667085;
      font-size: 16px;
      margin-top: 18px;
    }

    @keyframes teacherBootstrapPulse {
      from {
        opacity: 0.35;
        transform: scaleX(0.72);
      }

      to {
        opacity: 1;
        transform: scaleX(1);
      }
    }
  </style>
  <%- include('../partials/favicon.ejs') %>
  <% if (typeof renderScripts === "function") { %>
    <%- renderScripts(scripts) %>
  <% } %>
</head>
<body class="teacher-app" ng-controller="LocalesController">
  <div class="teacher-bootstrap-screen" ng-if="!translationsLoaded">
    <img
      src="/images/logos/ethicapp-logo.svg"
      class="teacher-bootstrap-logo"
      alt="EthicApp">
    <div class="teacher-bootstrap-loader"></div>
    <div class="teacher-bootstrap-message">Loading workspace...</div>
  </div>
  <div
    class="teacher-angular-shell"
    ng-cloak
    ng-if="translationsLoaded"
    ng-controller="<%= typeof controller !== 'undefined' ? controller : 'VoidController' %>">
  <%- body %>
  </div>
  <%- typeof bottomScripts !== 'undefined' ? bottomScripts : '' %>
</body>
</html>
