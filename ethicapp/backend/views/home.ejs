<script>
  window.__ETHICAPP_RECAPTCHA_ENABLED__ = <%= recaptchaEnabled ? "true" : "false" %>;
  window.__ETHICAPP_RECAPTCHA_SITE_KEY__ = "<%= recaptchaSiteKey || '' %>";
</script>
<% if (recaptchaEnabled) { %>
<script src="https://www.google.com/recaptcha/api.js?render=explicit" async defer></script>
<% } %>
<div
  class="teacher-workspace <%= impersonating && authRole === 'S' ? 'teacher-workspace-admin-inspection' : '' %>"
  ng-controller="ProfileController as vm"
  ng-class="{
    'teacher-sidebar-collapsed': teacherSidebarCollapsed,
    'teacher-sidebar-open': teacherSidebarOpen
  }">
  <header class="teacher-topbar">
    <div class="teacher-topbar-left">
      <button
        type="button"
        class="teacher-nav-toggle"
        ng-click="teacherSidebarCollapsed = !teacherSidebarCollapsed; teacherSidebarOpen = !teacherSidebarOpen"
        aria-label="Toggle navigation">
        <i class="fa fa-bars" aria-hidden="true"></i>
      </button>
      <a href="/home" class="teacher-topbar-brand">
        <img src="/images/logos/ethicapp-logo.svg" class="teacher-topbar-logo" alt="EthicApp">
      </a>
      <% if (impersonating && authRole === 'S') { %>
      <a href="/mng/users" class="btn btn-danger btn-sm teacher-admin-return">
        {{'back_to_management_console' | translate}}
      </a>
      <% } %>
    </div>

    <div class="teacher-topbar-actions">
      <div class="language-dropdown teacher-topbar-language"
        ng-mouseenter="showLanguageDropdown = true"
        ng-mouseleave="showLanguageDropdown = false">
        <span class="topbar-lang-icon"><i class="fa fa-globe" aria-hidden="true"></i></span>
        <i class="fa fa-angle-down" aria-hidden="true"></i>
        <ul class="language-options" ng-show="showLanguageDropdown">
          <li ng-repeat="languageKey in ['es_CL', 'en_US']" ng-click="changeLanguage(languageKey)">
            <span ng-if="languageKey === lang" class="selected-language">
              {{ getTranslatedLanguageName(languageKey) }} <i class="fa fa-check" aria-hidden="true"></i>
            </span>
            <span ng-if="languageKey !== lang" class="not-selected-language">
              {{ getTranslatedLanguageName(languageKey) }}
            </span>
          </li>
        </ul>
      </div>
      <a href="#!/profile" class="teacher-profile-link">
        <img ng-src="{{ vm.getTopbarAvatar() }}" alt="Avatar" class="circle_profile">
        <span class="teacher-profile-name">{{ vm.getDisplayName() || ('profile' | translate) }}</span>
      </a>
      <a href="/logout" class="teacher-logout-link" title="{{'exitEthicapp' | translate}}">
        <i class="fa fa-sign-out" aria-hidden="true"></i>
      </a>
    </div>
  </header>

  <div class="teacher-mobile-backdrop" ng-click="teacherSidebarOpen = false"></div>

  <aside class="teacher-sidebar">
    <nav aria-label="Teacher navigation">
      <ul class="teacher-nav-list">
        <li>
          <a href="#!/" ng-class="{'active': isTeacherNavActive('/')}" ng-click="teacherSidebarOpen = false" title="{{ 'nav_pill_title_home' | translate }}">
            <i class="fa fa-home" aria-hidden="true"></i>
            <span>{{ 'nav_pill_title_home' | translate }}</span>
          </a>
        </li>
        <li>
          <a href="#!/activities/new" ng-class="{'active': isTeacherNavActive('/activities/new')}" ng-click="teacherSidebarOpen = false" title="{{ 'nav_pill_title_launch_activity' | translate }}">
            <i class="fa-brands fa-space-awesome" aria-hidden="true"></i>
            <span>{{ 'nav_pill_title_launch_activity' | translate }}</span>
          </a>
        </li>
        <li>
          <a href="#!/activities" ng-class="{'active': isTeacherNavActive('/activities') && !isTeacherNavActive('/activities/new')}" ng-click="teacherSidebarOpen = false" title="{{ 'nav_pill_title_activities' | translate }}">
            <i class="fa-solid fa-drum" aria-hidden="true"></i>
            <span>{{ 'nav_pill_title_activities' | translate }}</span>
          </a>
        </li>
        <li>
          <a href="#!/designs" ng-class="{'active': isTeacherNavActive('/designs')}" ng-click="teacherSidebarOpen = false" title="{{ 'nav_pill_title_designs' | translate }}">
            <i class="fa fa-paint-brush" aria-hidden="true"></i>
            <span>{{ 'nav_pill_title_designs' | translate }}</span>
          </a>
        </li>
        <li>
          <a href="#!/cases" ng-class="{'active': isTeacherNavActive('/cases')}" ng-click="teacherSidebarOpen = false" title="{{ 'nav_pill_title_cases' | translate }}">
            <i class="fa fa-book" aria-hidden="true"></i>
            <span>{{ 'nav_pill_title_cases' | translate }}</span>
          </a>
        </li>
      </ul>
    </nav>
  </aside>

  <main class="teacher-main">
    <div class="teacher-main-inner">
      <div ng-view></div>
    </div>
  </main>
</div>
