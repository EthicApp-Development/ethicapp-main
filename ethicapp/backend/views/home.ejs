<script>
  window.__ETHICAPP_RECAPTCHA_ENABLED__ = <%= JSON.stringify(!!recaptchaEnabled) %>;
  window.__ETHICAPP_RECAPTCHA_SITE_KEY__ = <%= JSON.stringify(recaptchaSiteKey || '') %>;
</script>
<% if (recaptchaEnabled) { %>
<script src="https://www.google.com/recaptcha/api.js?render=explicit" async defer></script>
<% } %>
  <div ng-controller="ProfileController as vm" class="top-bar-mini cflex" ng-hide="false">
    <div class="cf1">
      <a href="/home" class="simple-margin-left">
        <img src="assets/images/logos/ethicapp-logo-emboss.png" class="logoEthicapp" alt="Logo">
      </a>
    </div>
    <div class="cf1 text-right margin-right-8 simple-padding-top" id="topbtnlist">
      <div class="language-dropdown" ng-mouseenter="showLanguageDropdown = true"
        ng-mouseleave="showLanguageDropdown = false">
        <i class="fa fa-globe"></i>
        <i class="fa fa-angle-down"></i>
        <ul class="language-options" ng-show="showLanguageDropdown">
          <li ng-repeat="languageKey in ['es_CL', 'en_US']" ng-click="changeLanguage(languageKey)">
            <span ng-if="languageKey === lang" class="selected-language">{{ getTranslatedLanguageName(languageKey) }} <i
                class="fa fa-check"></i></span>
            <span ng-if="languageKey !== lang" class="not-selected-language">{{ getTranslatedLanguageName(languageKey)
              }}</span>
          </li>
        </ul>
      </div>
      <div class="topbar-avatar-wrap margin-right-3 simple-padding-top">
        <img ng-src="{{ vm.getTopbarAvatar() }}" alt="Avatar" class="circle_profile">
      </div>
      <strong class="margin-right-8"><a href="#!/profile" style="color: white;"> {{ vm.getDisplayName() || ('profile' | translate) }}
        </a></strong>
      <a href="logout" class="text-white ml-2" title="{{'exitEthicapp' | translate}}">
        <i class="fa fa-sign-out fa-2x"></i>
      </a>
    </div>
  </div>
  <div>
  <div class="sidenav" style="margin-top: 5em;">
    <ul class="nav nav-pills nav-stacked">
        <li>
            <a href="#!/">
                <i class="fa fa-home" aria-hidden="true"></i> {{ 'nav_pill_title_home' | translate }}
            </a>
        </li>
        <li>
            <a href="#!/activities/new">
                <i class="fa-brands fa-space-awesome"></i> {{ 'nav_pill_title_launch_activity' | translate }}
            </a>
        </li>
        <li>
            <a href="#!/activities">
              <i class="fa-solid fa-drum"></i> {{ 'nav_pill_title_activities' | translate }}
            </a>
        </li>
        <li>
            <a href="#!/designs">
                <i class="fa fa-paint-brush" aria-hidden="true"></i> {{ 'nav_pill_title_designs' | translate }}
            </a>
        </li>
        <li>
            <a href="#!/cases">
                <i class="fa fa-book" aria-hidden="true"></i> {{ 'nav_pill_title_cases' | translate }}
            </a>
        </li>
    </ul>
  </div>  
  <div class="main_body vl"> <!--Right side-->
      <div class="container" style="margin-top: 3em;">
          <div ng-view></div>
      </div>
  </div>
