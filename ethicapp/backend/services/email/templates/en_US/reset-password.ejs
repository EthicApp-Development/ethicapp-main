<div style="
    max-width: 640px;
    padding: 24px;
    border: 1px solid #D3D3D3;
    margin: 20px auto;
    font-family: Arial, sans-serif;
    line-height: 1.5;
    color: #333;
    background-color: #ffffff;
">
    <div style="
        text-align: center;
        margin-bottom: 20px;
    ">
        <img src="cid:ethicappLogo" style="max-width: 200px;" alt="Ethicapp Logo" />
    </div>

    <p style="font-size: 16px;">Hello,</p>

    <p style="font-size: 16px;">Have you lost your password? Don't worry, you can reset it by clicking the link below:</p>

    <div style="text-align: center; margin: 20px 0;">
        <a href="<%= resetUrl %>" style="
            background-color: #2649EC;
            color: white;
            padding: 12px 20px;
            border-radius: 5px;
            text-decoration: none;
            display: inline-block;
            font-size: 16px;
        ">
            Reset Password
        </a>
    </div>

    <p style="font-size: 16px;">Best regards,</p>
    <p style="font-size: 16px;"><strong>EthicApp Team</strong></p>

    <p style="font-size: 12px; color: #777;">
        If you did not request this password change, you can ignore this message.
    </p>
</div>
