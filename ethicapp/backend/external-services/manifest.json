{
  "services": [
    {
      "id": "mock-ai-response-review",
      "description": "PoC adapter that simulates an AI service reviewing student responses.",
      "adapter": "./adapters/mock-ai-response-review.adapter.js",
      "hooks": [
        "student-response-submitted",
        "phaseStarted",
        "phaseEnded",
        "chat-message-received",
        "external-service-result"
      ],
      "enabled": true
    },
    {
      "id": "mock-chat-agent",
      "description": "PoC adapter that simulates a chat agent replying to group chat messages.",
      "adapter": "./adapters/mock-chat-agent.adapter.js",
      "hooks": [
        "chat-message-received"
      ],
      "enabled": true
    },
    {
      "id": "polyadic-devils-advocate",
      "description": "Bridge adapter that connects EthicApp group chats to the Polyadic Agents backend (Devil's Advocate pipeline).",
      "adapter": "./adapters/polyadic-bridge.adapter.js",
      "hooks": [
        "chat-message-received",
        "phaseStarted",
        "phaseEnded"
      ],
      "enabled": true
    }
  ]
}
