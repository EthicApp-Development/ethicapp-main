ETHICAPP_NODE_PORT=8501
POLYADIC_AGENTS_URL=http://localhost:5000
NODE_ENV=development
ETHICAPP_SESSION_COOKIE_NAME=ethicapp.sid
ETHICAPP_SESSION_COOKIE_SAMESITE=lax
ETHICAPP_SESSION_COOKIE_SECURE=false
ETHICAPP_SESSION_COOKIE_MAX_AGE_MS=86400000
ETHICAPP_SESSION_TTL_SECONDS=86400
ETHICAPP_SESSION_REDIS_PREFIX=ethicapp:sess:
ATS_API_BASE_URL=http://host.docker.internal:5001
ATS_POLL_INTERVAL_MS=2500
ATS_POLL_TIMEOUT_MS=90000
ATS_HTTP_TIMEOUT_MS=12000
ATS_KEYCLOAK_BASE_URL=http://host.docker.internal:8080
ATS_KEYCLOAK_REALM=argumentation-tutor
ATS_KEYCLOAK_CLIENT_ID=ethicapp-integration
ATS_KEYCLOAK_CLIENT_SECRET=replace_with_real_secret
ATS_KEYCLOAK_TOKEN_URL=
ATS_KEYCLOAK_SCOPE=
EXTERNAL_MOCK_SERVICE_URL=http://external-mock-service:8510
EXTERNAL_SERVICES_MANIFEST=/app/backend/external-services/manifest.json
ETHICAPP_PROCESS_ROLE=web
ETHICAPP_SEED_CANONICAL_ACTIVITIES=true
ETHICAPP_SEED_CANONICAL_ACTIVITIES_ATTEMPTS=12
ETHICAPP_SEED_TAG_TAXONOMIES=true
ETHICAPP_SEED_TAG_TAXONOMIES_ATTEMPTS=12
ETHICAPP_TAG_TAXONOMY_SEED_DIR=/database/seeds/tag-taxonomies
UPLOADS_PATH=/app/backend/uploads
PDF_RENDER_WORKER_CONCURRENCY=1
PDF_RENDER_WORKER_POLL_INTERVAL_MS=2000
PDF_RENDER_DPI=200
PDF_RENDER_MAX_PAGES=50
PDF_RENDER_TIMEOUT_MS=120000
