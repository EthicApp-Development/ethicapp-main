<div class="form-signin panel panel-default" ng-show="!emailSent">
    <div class="panel-body">
      <%- include("partials/logo") %>

      <% if (welc) { %>
      <div class="row mb-1em" ng-show="welcomeMessage" id="welcome-message" data-welc="<%= welc %>">
        <p class="welcome-message">{{ welcomeMessage | translate }}</p>
      </div>
      <% } %>    

      <div class="row mb-1em">
        <div class="col-sm-12">
          <p>{{ "pass_recovery_directions" | translate }}</p>
        </div>
      </div>
      <div class="row">
        <form ng-submit="requestPasswordChange()" class="form-horizontal" name="formEmailRequest" novalidate>
          <div class="form-group">
            <label for="email" class="col-sm-3 control-label">{{ "email" | translate }}</label>
            <div class="col-sm-8">
              <input class="form-control" ng-focus="clearErrors()" type="email" ng-model="user.email" name="email" id="email" ng-required="true" autofocus />
              <div class="error-message" ng-show="formEmailRequest.email.$error.required && formEmailRequest.email.$touched" style="color: red;">
                {{ "email_required" | translate }}
              </div>
              <div class="error-message" ng-show="formEmailRequest.email.$error.email && formEmailRequest.email.$touched" style="color: red;">
                {{ "invalid_email" | translate }}
              </div>
            </div>
            <div class="col-sm-8 mb-1em">
            </div>
          </div>
  
          <div class="form-group text-center">
            <div class="g-recaptcha" id="captcha" data-type="image"></div>
            <div class="error-message" ng-show="recaptchaError" style="color: red;">
              {{ recaptchaError | translate }}
            </div>
          </div>
          
          <div class="form-group text-center">
            <div class="error-message" ng-show="backendError" style="margin-bottom:1em; color: red;">
              {{ backendErrorMessage | translate }}
            </div>
            <button type="submit" class="btn btn-primary" ng-disabled="formEmailRequest.$invalid" style="margin: 0 auto; width:140px;">
              {{ "send_reset_link" | translate }}
            </button>
          </div>          
        </form>
      </div>
      <div class="row">
        <div class="col-sm-12 text-center">
          <a href="/login" style="margin-top: 8px">{{ "back_to_login" | translate }}</a>
        </div>
      </div>      
    </div>
</div>

<div class="form-signin panel panel-default" ng-show="emailSent">
  <%- include("partials/logo") %>
  <div class="row mb-1em">
    <p class="text-center">{{ "password_recovery_email_sent" | translate }}</p>
  </div>
</div>