# URL pública del auth backend (sin slash final)
VITE_AUTH_PUBLIC_URL=http://localhost:3000

# Si se omite, se construye automáticamente como:
# VITE_AUTH_PUBLIC_URL + /api/auth
VITE_AUTH_API_BASE_URL=http://localhost:3000/api/auth

# Clave pública de Google reCAPTCHA v2
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key
