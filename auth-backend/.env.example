PORT=3000
NODE_ENV=development
DEBUG_SQL=false

SESSION_SECRET=change_me
SESSION_COOKIE_NAME=auth.sid
BCRYPT_SALT_ROUNDS=10
RESET_TOKEN_TTL_MINUTES=60

PGHOST=postgresql
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=ethicapp
PGPOOL_MAX=10
PG_IDLE_TIMEOUT=30000
PG_CONN_TIMEOUT=2000

# URL pública del auth backend
# Ejemplo: https://auth.mi-dominio.com
AUTH_PUBLIC_URL=http://localhost:3000

# API base para frontend Vite (si no se define, frontend usa VITE_AUTH_PUBLIC_URL + /api/auth)
VITE_AUTH_PUBLIC_URL=http://localhost:3000
VITE_AUTH_API_BASE_URL=http://localhost:3000/api/auth

# reCAPTCHA v2 (Google)
RECAPTCHA_ENABLED=true
RECAPTCHA_SECRET_KEY=your_recaptcha_v2_secret
RECAPTCHA_VERIFY_URL=https://www.google.com/recaptcha/api/siteverify
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v2_site_key

# SMTP saliente
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=super_secret_password
SMTP_FROM="EthicApp <no-reply@example.com>"
