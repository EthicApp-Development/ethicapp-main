# EthicApp production backup kit environment.
# Copy this file to .env, fill production values, and keep it outside git.

BACKUP_DIR=/var/backups/ethicapp
BACKUP_PREFIX=ethicapp
BACKUP_RETENTION_COUNT=7

# Set this when PostgreSQL client commands should run inside the database
# container. Leave empty when pg_dump/dropdb/createdb/pg_restore run on the host.
BACKUP_DB_CONTAINER=ethicapp-db

# Uploads must be the host path where the protected uploads volume is mounted.
BACKUP_UPLOADS=true
UPLOADS_PATH=/srv/ethicapp/uploads

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=replace-with-production-secret
PGDATABASE=ethicapp
PGSSLMODE=disable

# Restore options.
PRODUCTION_RESTORE_FORCE=false
RESTORE_UPLOADS=true
RESTORE_UPLOADS_REPLACE=true
