{
  "name": "ethicapp-scripts",
  "description": "Repository-level development and maintenance scripts for EthicApp",
  "private": true,
  "type": "module",
  "scripts": {
    "lint-js": "npx eslint './ethicapp/**/*.js' ./ethicapp/backend/ethicapp",
    "lint-html": "npx htmlhint './ethicapp/frontend/assets/static/**/*.html'",
    "lint-css": "npx stylelint './ethicapp/frontend/assets/css/**/*.css'",
    "lint-sql": "sqlfluff lint ./database/",
    "fix-js": "npx eslint --fix './ethicapp/**/*.js' ./ethicapp/backend/ethicapp",
    "fix-css": "npx stylelint --fix './ethicapp/frontend/assets/css/**/*.css'",
    "fix-sql": "sqlfluff fix --show-lint-violations --force ./database/",
    "db:migrate": "docker compose run --rm flyway migrate",
    "db:info": "docker compose run --rm flyway info",
    "db:validate": "docker compose run --rm flyway validate",
    "clear-sessions": "sudo rm -f -v ./ethicapp/backend/sessions/*",
    "pgdump": "./scripts/docker-pgdump.sh",
    "pgrestore": "./scripts/docker-pgrestore.sh",
    "backup:production": "./scripts/production-backup.sh",
    "restore:production": "./scripts/production-restore.sh",
    "backup:package": "./scripts/export-production-backup-package.sh",
    "psql": "./scripts/docker-psql.sh",
    "anonymization:maintenance": "./scripts/student-anonymization-maintenance.sh",
    "build:ethicapp-assets": "./scripts/build-ethicapp-assets.sh",
    "publish:ghcr": "./scripts/ghcr-build-push.sh"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-angular": "^4.1.0",
    "htmlhint": "^1.9.2",
    "stylelint": "^17.11.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "cross-spawn": "^7.0.6",
    "minimatch": "^3.1.4",
    "picomatch": "^2.3.2"
  }
}
