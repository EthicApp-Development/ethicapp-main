NODE_ENV=development
ETHICAPP_WATCH_FRONTEND=true
NGINX_MAINTENANCE_MODE=false
NGINX_MAINTENANCE_RETRY_AFTER=3600
STUDENT_ANONYMIZATION_WINDOW_SCHEDULE=01-01,07-01
STUDENT_ANONYMIZATION_WINDOW_TIMEZONE=deployment-local
REDIS_SESSION_MAXMEMORY=128mb
REDIS_SESSION_MAXMEMORY_POLICY=volatile-ttl
REDIS_CACHE_MAXMEMORY=256mb
REDIS_CACHE_MAXMEMORY_POLICY=allkeys-lru
